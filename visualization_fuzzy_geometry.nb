Cell["Section 3. Execution Pipeline", "Section",
 CellChangeTimes->{{3.9911364126139526`*^9, 
  3.991136414798708*^9}},ExpressionUUID->"4640de8e-019a-3a46-b1f1-\
75362c2e051a"],

Cell["Application to the examples.", "Text",
