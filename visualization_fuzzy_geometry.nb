Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"3.1", ".", "Fuzzy"}], " ", "2"}], "-", 
    RowBox[{"Sphere", " ", "Validation"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"fuzzyN", "=", "20"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"mySphereMatrices", "=", 
