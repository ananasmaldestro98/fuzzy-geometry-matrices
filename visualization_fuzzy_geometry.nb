Notebook[{

Cell[CellGroupData[{
Cell[TextData[StyleBox["Analyzing Fuzzy Geometries and Coherent States",
 FontWeight->"Bold"]], "Title",
 CellChangeTimes->{
  3.991136255725807*^9},ExpressionUUID->"d79f9b75-73a0-be43-8fa8-\
765166189b43"],

Cell["\<\
This notebook provides a computational framework for constructing and \
analyzing matrix representations of fuzzy geometries. We define the matrix \
coordinates for the fuzzy 2-sphere, fuzzy 4-hyperboloid, and fuzzy 4-sphere \
using $O(1)$ hash map lookups to efficiently generate the sparse matrix \
elements from their defining algebraic relations. The AnalyzeFuzzyGeometry \
pipeline then extracts coherent states by finding the ground state of the \
optimally localized Hamiltonian and plots the resulting emergent classical \
geometry.
See https://arxiv.org/pdf/2009.03400 for mathematical details about the \
construction. From the quasi-coherent states, one can study quantum (Berry) \
properties of such fuzzy spaces.\
\>", "Text",
 CellChangeTimes->{
  3.9911362300718555`*^9, {3.9912111594186134`*^9, 
   3.991211223431902*^9}},ExpressionUUID->"91c89269-0e8c-5940-9089-\
2b4852251d21"],

Cell[CellGroupData[{

Cell["Section 1. Defining Examples of Matrix Geometries", "Section",
 CellChangeTimes->{{3.991136302130689*^9, 3.991136311502201*^9}, 
   3.991211090861719*^9, {3.991211244058527*^9, 
   3.9912112456111336`*^9}},ExpressionUUID->"82a25fde-487a-1a4e-a405-\
cf99f625231d"],

Cell["\<\
In this section we will construct prototypical matrix geometries that we will \
later visualize. These are the fuzzy 2-sphere, i.e. the matrix coordinates \
for the 2-sphere, constructed from generators of irreps of SU(2); the fuzzy \
4-hyperboloid, from specific (truncated) irreps of SO(4,1); the fuzzy \
4-sphere, from SO(5) irreps.\
\>", "Text",
 CellChangeTimes->{{3.991211254504198*^9, 
  3.991211363252199*^9}},ExpressionUUID->"86fd8486-d9bc-5443-8d05-\
e765039fcf5a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{"FuzzySphereMatrices", ",", "AnalyzeFuzzyGeometry"}], "]"}], 
   ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"1.1", ".", "Fuzzy"}], " ", "2"}], "-", "Sphere"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FuzzySphereMatrices", "[", "Nint_Integer", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "dim", ",", "Cnorm", ",", "diag3", ",", "subDiag", ",", "X1", ",", "X2", 
      ",", "X3"}], "}"}], ",", 
    RowBox[{
     RowBox[{"dim", "=", 
      RowBox[{"Nint", "+", "1"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Cnorm", "=", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"0.25", "*", "Nint", "*", 
        RowBox[{"(", 
         RowBox[{"Nint", "+", "2"}], ")"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"diag3", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"0.5", "*", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "*", 
             RowBox[{"(", 
              RowBox[{"j", "-", "1"}], ")"}]}], "-", "Nint"}], ")"}], "/", 
          "Cnorm"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "dim"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"subDiag", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"0.5", "*", 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{"j", "*", 
            RowBox[{"(", 
             RowBox[{"Nint", "-", "j", "+", "1"}], ")"}]}], "]"}], "/", 
          "Cnorm"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", 
          RowBox[{"dim", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"X3", "=", 
      RowBox[{"DiagonalMatrix", "[", "diag3", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"X1", "=", 
      RowBox[{
       RowBox[{"DiagonalMatrix", "[", 
        RowBox[{"subDiag", ",", 
         RowBox[{"-", "1"}]}], "]"}], "+", 
       RowBox[{"DiagonalMatrix", "[", 
        RowBox[{"subDiag", ",", "1"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"X2", "=", 
      RowBox[{
       RowBox[{"DiagonalMatrix", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "I"}], "*", "subDiag"}], ",", 
         RowBox[{"-", "1"}]}], "]"}], "+", 
       RowBox[{"DiagonalMatrix", "[", 
        RowBox[{
         RowBox[{"I", "*", "subDiag"}], ",", "1"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"X1", ",", "X2", ",", "X3"}], "}"}]}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9911363134353337`*^9, 
  3.991136329663189*^9}},ExpressionUUID->"ac79c447-d3f7-0d45-9795-\
6e77cfc94dc9"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "Fuzzy4HyperboloidMatrices", "]"}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"1.2", ".", "Fuzzy"}], " ", "4"}], "-", "Hyperboloid"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Fuzzy4HyperboloidMatrices", "[", 
   RowBox[{"Nint_Integer", ",", "Mint_Integer"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "states", ",", "dim", ",", "stateToIndex", ",", "rules", ",", "mats"}], 
     "}"}], ",", 
    RowBox[{"(*", 
     RowBox[{
     "Generate", " ", "valid", " ", "states", " ", "and", " ", "create", " ", 
      "O", 
      RowBox[{"(", "1", ")"}], " ", "hash", " ", "map", " ", "lookup"}], 
     "*)"}], 
    RowBox[{
     RowBox[{"states", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"m", ",", "i", ",", "k"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"m", ",", "0", ",", "Mint"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "0", ",", 
            RowBox[{"Nint", "+", "m"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "0", ",", "m"}], "}"}]}], "]"}], ",", "2"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"dim", "=", 
      RowBox[{"Length", "[", "states", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"stateToIndex", "=", 
      RowBox[{"AssociationThread", "[", 
       RowBox[{"states", "->", 
        RowBox[{"Range", "[", "dim", "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "Iterate", " ", "through", " ", "states", " ", "and", " ", "apply", " ",
        "algebraic", " ", "rules", " ", "to", " ", "build", " ", "matrix", 
       " ", "elements"}], "*)"}], 
     RowBox[{"rules", "=", 
      RowBox[{
       RowBox[{"Reap", "[", 
        RowBox[{
         RowBox[{"Do", "[", 
          RowBox[{
           RowBox[{"Module", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
              "m2", ",", "i", ",", "k", ",", "j", ",", "colIdx", ",", 
               "sowIfValid"}], "}"}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{"{", 
                RowBox[{"m2", ",", "i", ",", "k"}], "}"}], "=", "state"}], 
              ";", 
              RowBox[{"(*", 
               RowBox[{
               "Destructuring", " ", "for", " ", "cleaner", " ", "variable", 
                " ", "assignment"}], "*)"}], 
              RowBox[{"j", "=", 
               RowBox[{"Nint", "+", "m2", "-", "i"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"colIdx", "=", 
               RowBox[{"stateToIndex", "[", "state", "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
               "Helper", " ", "function", " ", "to", " ", "map", " ", "to", 
                " ", "a", " ", "valid", " ", "row", " ", "state", " ", "and", 
                " ", "sow", " ", "elements"}], "*)"}], 
              RowBox[{
               RowBox[{"sowIfValid", "[", 
                RowBox[{
                "m1_", ",", "a_", ",", "c_", ",", "valX0_", ",", "valX1_", 
                 ",", "valX2_", ",", "valX3_", ",", "valX4_"}], "]"}], ":=", 
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"KeyExistsQ", "[", 
                  RowBox[{"stateToIndex", ",", 
                   RowBox[{"{", 
                    RowBox[{"m1", ",", "a", ",", "c"}], "}"}]}], "]"}], ",", 
                 RowBox[{"Module", "[", 
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{"rowIdx", "=", 
                    RowBox[{"stateToIndex", "[", 
                    RowBox[{"{", 
                    RowBox[{"m1", ",", "a", ",", "c"}], "}"}], "]"}]}], "}"}],
                    ",", 
                   RowBox[{
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"valX0", "!=", "0"}], ",", 
                    RowBox[{"Sow", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"rowIdx", ",", "colIdx"}], "}"}], "->", "valX0"}],
                     ",", "\"\<X0\>\""}], "]"}]}], "]"}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"valX1", "!=", "0"}], ",", 
                    RowBox[{"Sow", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"rowIdx", ",", "colIdx"}], "}"}], "->", "valX1"}],
                     ",", "\"\<X1\>\""}], "]"}]}], "]"}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"valX2", "!=", "0"}], ",", 
                    RowBox[{"Sow", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"rowIdx", ",", "colIdx"}], "}"}], "->", "valX2"}],
                     ",", "\"\<X2\>\""}], "]"}]}], "]"}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"valX3", "!=", "0"}], ",", 
                    RowBox[{"Sow", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"rowIdx", ",", "colIdx"}], "}"}], "->", "valX3"}],
                     ",", "\"\<X3\>\""}], "]"}]}], "]"}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"valX4", "!=", "0"}], ",", 
                    RowBox[{"Sow", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"rowIdx", ",", "colIdx"}], "}"}], "->", "valX4"}],
                     ",", "\"\<X4\>\""}], "]"}]}], "]"}], ";"}]}], "]"}]}], 
                "]"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{"Algebraic", " ", "mapping", " ", "rules"}], "*)"}], 
              RowBox[{"sowIfValid", "[", 
               RowBox[{"m2", ",", "i", ",", "k", ",", 
                RowBox[{"0.5", "*", 
                 RowBox[{"(", 
                  RowBox[{"Nint", "+", 
                   RowBox[{"2", "*", "m2"}], "+", "2"}], ")"}]}], ",", "0", 
                ",", "0", ",", "0", ",", "0"}], "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"sowIfValid", "[", 
               RowBox[{
                RowBox[{"m2", "-", "1"}], ",", 
                RowBox[{"i", "-", "1"}], ",", "k", ",", "0", ",", 
                RowBox[{
                 RowBox[{"Sqrt", "[", 
                  RowBox[{"i", "*", 
                   RowBox[{"(", 
                    RowBox[{"m2", "-", "k"}], ")"}]}], "]"}], "/", "2"}], ",", 
                RowBox[{
                 RowBox[{"-", "I"}], "*", 
                 RowBox[{
                  RowBox[{"Sqrt", "[", 
                   RowBox[{"i", "*", 
                    RowBox[{"(", 
                    RowBox[{"m2", "-", "k"}], ")"}]}], "]"}], "/", "2"}]}], 
                ",", "0", ",", "0"}], "]"}], ";", "\[IndentingNewLine]", 
              RowBox[{"sowIfValid", "[", 
               RowBox[{
                RowBox[{"m2", "+", "1"}], ",", 
                RowBox[{"i", "+", "1"}], ",", "k", ",", "0", ",", 
                RowBox[{
                 RowBox[{"Sqrt", "[", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"i", "+", "1"}], ")"}], "*", 
                   RowBox[{"(", 
                    RowBox[{"m2", "-", "k", "+", "1"}], ")"}]}], "]"}], "/", 
                 "2"}], ",", 
                RowBox[{"I", "*", 
                 RowBox[{
                  RowBox[{"Sqrt", "[", 
                   RowBox[{
                    RowBox[{"(", 
                    RowBox[{"i", "+", "1"}], ")"}], "*", 
                    RowBox[{"(", 
                    RowBox[{"m2", "-", "k", "+", "1"}], ")"}]}], "]"}], "/", 
                  "2"}]}], ",", "0", ",", "0"}], "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"sowIfValid", "[", 
               RowBox[{
                RowBox[{"m2", "-", "1"}], ",", "i", ",", 
                RowBox[{"k", "-", "1"}], ",", "0", ",", 
                RowBox[{
                 RowBox[{"Sqrt", "[", 
                  RowBox[{"j", "*", "k"}], "]"}], "/", "2"}], ",", 
                RowBox[{"I", "*", 
                 RowBox[{
                  RowBox[{"Sqrt", "[", 
                   RowBox[{"j", "*", "k"}], "]"}], "/", "2"}]}], ",", "0", 
                ",", "0"}], "]"}], ";", "\[IndentingNewLine]", 
              RowBox[{"sowIfValid", "[", 
               RowBox[{
                RowBox[{"m2", "+", "1"}], ",", "i", ",", 
                RowBox[{"k", "+", "1"}], ",", "0", ",", 
                RowBox[{
                 RowBox[{"Sqrt", "[", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"j", "+", "1"}], ")"}], "*", 
                   RowBox[{"(", 
                    RowBox[{"k", "+", "1"}], ")"}]}], "]"}], "/", "2"}], ",", 
                RowBox[{
                 RowBox[{"-", "I"}], "*", 
                 RowBox[{
                  RowBox[{"Sqrt", "[", 
                   RowBox[{
                    RowBox[{"(", 
                    RowBox[{"j", "+", "1"}], ")"}], "*", 
                    RowBox[{"(", 
                    RowBox[{"k", "+", "1"}], ")"}]}], "]"}], "/", "2"}]}], 
                ",", "0", ",", "0"}], "]"}], ";", "\[IndentingNewLine]", 
              RowBox[{"sowIfValid", "[", 
               RowBox[{
                RowBox[{"m2", "-", "1"}], ",", 
                RowBox[{"i", "-", "1"}], ",", 
                RowBox[{"k", "-", "1"}], ",", "0", ",", "0", ",", "0", ",", 
                RowBox[{
                 RowBox[{"Sqrt", "[", 
                  RowBox[{"i", "*", "k"}], "]"}], "/", "2"}], ",", 
                RowBox[{
                 RowBox[{"-", "I"}], "*", 
                 RowBox[{
                  RowBox[{"Sqrt", "[", 
                   RowBox[{"i", "*", "k"}], "]"}], "/", "2"}]}]}], "]"}], ";",
               "\[IndentingNewLine]", 
              RowBox[{"sowIfValid", "[", 
               RowBox[{
                RowBox[{"m2", "+", "1"}], ",", 
                RowBox[{"i", "+", "1"}], ",", 
                RowBox[{"k", "+", "1"}], ",", "0", ",", "0", ",", "0", ",", 
                RowBox[{
                 RowBox[{"Sqrt", "[", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"i", "+", "1"}], ")"}], "*", 
                   RowBox[{"(", 
                    RowBox[{"k", "+", "1"}], ")"}]}], "]"}], "/", "2"}], ",", 
                RowBox[{"I", "*", 
                 RowBox[{
                  RowBox[{"Sqrt", "[", 
                   RowBox[{
                    RowBox[{"(", 
                    RowBox[{"i", "+", "1"}], ")"}], "*", 
                    RowBox[{"(", 
                    RowBox[{"k", "+", "1"}], ")"}]}], "]"}], "/", "2"}]}]}], 
               "]"}], ";", "\[IndentingNewLine]", 
              RowBox[{"sowIfValid", "[", 
               RowBox[{
                RowBox[{"m2", "-", "1"}], ",", "i", ",", "k", ",", "0", ",", 
                "0", ",", "0", ",", 
                RowBox[{
                 RowBox[{"-", 
                  RowBox[{"Sqrt", "[", 
                   RowBox[{"j", "*", 
                    RowBox[{"(", 
                    RowBox[{"m2", "-", "k"}], ")"}]}], "]"}]}], "/", "2"}], 
                ",", 
                RowBox[{
                 RowBox[{"-", "I"}], "*", 
                 RowBox[{
                  RowBox[{"Sqrt", "[", 
                   RowBox[{"j", "*", 
                    RowBox[{"(", 
                    RowBox[{"m2", "-", "k"}], ")"}]}], "]"}], "/", "2"}]}]}], 
               "]"}], ";", "\[IndentingNewLine]", 
              RowBox[{"sowIfValid", "[", 
               RowBox[{
                RowBox[{"m2", "+", "1"}], ",", "i", ",", "k", ",", "0", ",", 
                "0", ",", "0", ",", 
                RowBox[{
                 RowBox[{"-", 
                  RowBox[{"Sqrt", "[", 
                   RowBox[{
                    RowBox[{"(", 
                    RowBox[{"j", "+", "1"}], ")"}], "*", 
                    RowBox[{"(", 
                    RowBox[{"m2", "-", "k", "+", "1"}], ")"}]}], "]"}]}], "/",
                  "2"}], ",", 
                RowBox[{"I", "*", 
                 RowBox[{
                  RowBox[{"Sqrt", "[", 
                   RowBox[{
                    RowBox[{"(", 
                    RowBox[{"j", "+", "1"}], ")"}], "*", 
                    RowBox[{"(", 
                    RowBox[{"m2", "-", "k", "+", "1"}], ")"}]}], "]"}], "/", 
                  "2"}]}]}], "]"}], ";"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"state", ",", "states"}], "}"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{
          "\"\<X0\>\"", ",", "\"\<X1\>\"", ",", "\"\<X2\>\"", ",", 
           "\"\<X3\>\"", ",", "\"\<X4\>\""}], "}"}]}], "]"}], "[", 
       RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "Convert", " ", "gathered", " ", "elements", " ", "into", " ", 
       "SparseArrays"}], "*)"}], 
     RowBox[{"mats", "=", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"#", "===", 
            RowBox[{"{", "}"}]}], ",", 
           RowBox[{"SparseArray", "[", 
            RowBox[{
             RowBox[{"{", "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"dim", ",", "dim"}], "}"}]}], "]"}], ",", 
           RowBox[{"SparseArray", "[", 
            RowBox[{
             RowBox[{"#", "[", 
              RowBox[{"[", "1", "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"dim", ",", "dim"}], "}"}]}], "]"}]}], "]"}], "&"}], 
        ",", "rules"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{
      "\"\<Generated H4 Matrices for N=\>\"", ",", "Nint", ",", 
       "\"\<, M=\>\"", ",", "Mint", ",", "\"\< (Dimension d=\>\"", ",", "dim",
        ",", "\"\<)\>\""}], "]"}], ";", "\[IndentingNewLine]", "mats"}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.9911363308882008`*^9, 
  3.9911363327208347`*^9}},ExpressionUUID->"467e5186-8b45-1d4f-8de8-\
e1680e7dc042"],

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "Fuzzy4SphereMatrices", "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"1.3", ".", "Fuzzy"}], " ", "4"}], "-", "Sphere"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Fuzzy4SphereMatrices", "[", "Nint_Integer", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "states", ",", "dim", ",", "stateToIndex", ",", "rules", ",", "mats"}],
        "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
         RowBox[{
         "Generate", " ", "valid", " ", "states", " ", "with", " ", 
          "condition", " ", "i"}], "+", "j", "+", "k"}], "<=", "Nint"}], 
       "*)"}], 
      RowBox[{
       RowBox[{"states", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"i", ",", "j", ",", "k"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "0", ",", "Nint"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"j", ",", "0", ",", 
              RowBox[{"Nint", "-", "i"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", "0", ",", 
              RowBox[{"Nint", "-", "i", "-", "j"}]}], "}"}]}], "]"}], ",", 
          "2"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"dim", "=", 
        RowBox[{"Length", "[", "states", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"stateToIndex", "=", 
        RowBox[{"AssociationThread", "[", 
         RowBox[{"states", "->", 
          RowBox[{"Range", "[", "dim", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"rules", "=", 
        RowBox[{
         RowBox[{"Reap", "[", 
          RowBox[{
           RowBox[{"Do", "[", 
            RowBox[{
             RowBox[{"Module", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                "i", ",", "j", ",", "k", ",", "colIdx", ",", "sowIfValid"}], 
                "}"}], ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"i", ",", "j", ",", "k"}], "}"}], "=", "state"}], 
                ";", "\[IndentingNewLine]", 
                RowBox[{"colIdx", "=", 
                 RowBox[{"stateToIndex", "[", "state", "]"}]}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"sowIfValid", "[", 
                  RowBox[{
                  "a_", ",", "b_", ",", "c_", ",", "valX5_", ",", "valX1_", 
                   ",", "valX2_", ",", "valX3_", ",", "valX4_"}], "]"}], ":=", 
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{"KeyExistsQ", "[", 
                    RowBox[{"stateToIndex", ",", 
                    RowBox[{"{", 
                    RowBox[{"a", ",", "b", ",", "c"}], "}"}]}], "]"}], ",", 
                   RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"rowIdx", "=", 
                    RowBox[{"stateToIndex", "[", 
                    RowBox[{"{", 
                    RowBox[{"a", ",", "b", ",", "c"}], "}"}], "]"}]}], "}"}], 
                    ",", 
                    RowBox[{
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"valX5", "!=", "0"}], ",", 
                    RowBox[{"Sow", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"rowIdx", ",", "colIdx"}], "}"}], "->", "valX5"}],
                     ",", "\"\<X5\>\""}], "]"}]}], "]"}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"valX1", "!=", "0"}], ",", 
                    RowBox[{"Sow", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"rowIdx", ",", "colIdx"}], "}"}], "->", "valX1"}],
                     ",", "\"\<X1\>\""}], "]"}]}], "]"}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"valX2", "!=", "0"}], ",", 
                    RowBox[{"Sow", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"rowIdx", ",", "colIdx"}], "}"}], "->", "valX2"}],
                     ",", "\"\<X2\>\""}], "]"}]}], "]"}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"valX3", "!=", "0"}], ",", 
                    RowBox[{"Sow", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"rowIdx", ",", "colIdx"}], "}"}], "->", "valX3"}],
                     ",", "\"\<X3\>\""}], "]"}]}], "]"}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"valX4", "!=", "0"}], ",", 
                    RowBox[{"Sow", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"rowIdx", ",", "colIdx"}], "}"}], "->", "valX4"}],
                     ",", "\"\<X4\>\""}], "]"}]}], "]"}], ";"}]}], "]"}]}], 
                  "]"}]}], ";", "\[IndentingNewLine]", 
                RowBox[{"(*", 
                 RowBox[{"Algebraic", " ", "mapping", " ", "rules"}], "*)"}], 
                RowBox[{"sowIfValid", "[", 
                 RowBox[{"i", ",", "j", ",", "k", ",", 
                  RowBox[{"0.5", "*", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"2", "*", "i"}], "+", 
                    RowBox[{"2", "*", "j"}], "-", "Nint"}], ")"}]}], ",", "0",
                   ",", "0", ",", "0", ",", "0"}], "]"}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"sowIfValid", "[", 
                 RowBox[{
                  RowBox[{"i", "+", "1"}], ",", "j", ",", "k", ",", "0", ",", 
                  RowBox[{"I", "*", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", 
                    RowBox[{"Sqrt", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"Nint", "-", "i", "-", "j", "-", "k"}], ")"}], 
                    "*", 
                    RowBox[{"(", 
                    RowBox[{"i", "+", "1"}], ")"}]}], "]"}]}], "/", "2"}], 
                    ")"}]}], ",", 
                  RowBox[{
                   RowBox[{"Sqrt", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"Nint", "-", "i", "-", "j", "-", "k"}], ")"}], 
                    "*", 
                    RowBox[{"(", 
                    RowBox[{"i", "+", "1"}], ")"}]}], "]"}], "/", "2"}], ",", 
                  "0", ",", "0"}], "]"}], ";", "\[IndentingNewLine]", 
                RowBox[{"sowIfValid", "[", 
                 RowBox[{
                  RowBox[{"i", "-", "1"}], ",", "j", ",", "k", ",", "0", ",", 
                  RowBox[{"I", "*", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"Sqrt", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"Nint", "-", "i", "-", "j", "-", "k", "+", "1"}], 
                    ")"}], "*", "i"}], "]"}], "/", "2"}], ")"}]}], ",", 
                  RowBox[{
                   RowBox[{"Sqrt", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"Nint", "-", "i", "-", "j", "-", "k", "+", "1"}], 
                    ")"}], "*", "i"}], "]"}], "/", "2"}], ",", "0", ",", 
                  "0"}], "]"}], ";", "\[IndentingNewLine]", 
                RowBox[{"sowIfValid", "[", 
                 RowBox[{"i", ",", 
                  RowBox[{"j", "+", "1"}], ",", 
                  RowBox[{"k", "-", "1"}], ",", "0", ",", 
                  RowBox[{"I", "*", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", 
                    RowBox[{"Sqrt", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"j", "+", "1"}], ")"}], "*", "k"}], "]"}]}], "/", 
                    "2"}], ")"}]}], ",", 
                  RowBox[{
                   RowBox[{"-", 
                    RowBox[{"Sqrt", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"j", "+", "1"}], ")"}], "*", "k"}], "]"}]}], "/", 
                   "2"}], ",", "0", ",", "0"}], "]"}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"sowIfValid", "[", 
                 RowBox[{"i", ",", 
                  RowBox[{"j", "-", "1"}], ",", 
                  RowBox[{"k", "+", "1"}], ",", "0", ",", 
                  RowBox[{"I", "*", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"Sqrt", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"k", "+", "1"}], ")"}], "*", "j"}], "]"}], "/", 
                    "2"}], ")"}]}], ",", 
                  RowBox[{
                   RowBox[{"-", 
                    RowBox[{"Sqrt", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"k", "+", "1"}], ")"}], "*", "j"}], "]"}]}], "/", 
                   "2"}], ",", "0", ",", "0"}], "]"}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"sowIfValid", "[", 
                 RowBox[{
                  RowBox[{"i", "+", "1"}], ",", "j", ",", 
                  RowBox[{"k", "-", "1"}], ",", "0", ",", "0", ",", "0", ",", 
                  RowBox[{"I", "*", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", 
                    RowBox[{"Sqrt", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"i", "+", "1"}], ")"}], "*", "k"}], "]"}]}], "/", 
                    "2"}], ")"}]}], ",", 
                  RowBox[{
                   RowBox[{"Sqrt", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"i", "+", "1"}], ")"}], "*", "k"}], "]"}], "/", 
                   "2"}]}], "]"}], ";", "\[IndentingNewLine]", 
                RowBox[{"sowIfValid", "[", 
                 RowBox[{
                  RowBox[{"i", "-", "1"}], ",", "j", ",", 
                  RowBox[{"k", "+", "1"}], ",", "0", ",", "0", ",", "0", ",", 
                  RowBox[{"I", "*", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"Sqrt", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"k", "+", "1"}], ")"}], "*", "i"}], "]"}], "/", 
                    "2"}], ")"}]}], ",", 
                  RowBox[{
                   RowBox[{"Sqrt", "[", 
                    RowBox[{"i", "*", 
                    RowBox[{"(", 
                    RowBox[{"k", "+", "1"}], ")"}]}], "]"}], "/", "2"}]}], 
                 "]"}], ";", "\[IndentingNewLine]", 
                RowBox[{"sowIfValid", "[", 
                 RowBox[{"i", ",", 
                  RowBox[{"j", "+", "1"}], ",", "k", ",", "0", ",", "0", ",", 
                  "0", ",", 
                  RowBox[{"I", "*", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"Sqrt", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"Nint", "-", "i", "-", "j", "-", "k"}], ")"}], 
                    "*", 
                    RowBox[{"(", 
                    RowBox[{"j", "+", "1"}], ")"}]}], "]"}], "/", "2"}], 
                    ")"}]}], ",", 
                  RowBox[{
                   RowBox[{"Sqrt", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"j", "+", "1"}], ")"}], "*", 
                    RowBox[{"(", 
                    RowBox[{"Nint", "-", "i", "-", "j", "-", "k"}], ")"}]}], 
                    "]"}], "/", "2"}]}], "]"}], ";", "\[IndentingNewLine]", 
                RowBox[{"sowIfValid", "[", 
                 RowBox[{"i", ",", 
                  RowBox[{"j", "-", "1"}], ",", "k", ",", "0", ",", "0", ",", 
                  "0", ",", 
                  RowBox[{"I", "*", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", 
                    RowBox[{"Sqrt", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"Nint", "-", "i", "-", "j", "-", "k", "+", "1"}], 
                    ")"}], "*", "j"}], "]"}]}], "/", "2"}], ")"}]}], ",", 
                  RowBox[{
                   RowBox[{"Sqrt", "[", 
                    RowBox[{"j", "*", 
                    RowBox[{"(", 
                    RowBox[{"Nint", "-", "i", "-", "j", "-", "k", "+", "1"}], 
                    ")"}]}], "]"}], "/", "2"}]}], "]"}], ";"}]}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"state", ",", "states"}], "}"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
            "\"\<X5\>\"", ",", "\"\<X1\>\"", ",", "\"\<X2\>\"", ",", 
             "\"\<X3\>\"", ",", "\"\<X4\>\""}], "}"}]}], "]"}], "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"mats", "=", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"#", "===", 
              RowBox[{"{", "}"}]}], ",", 
             RowBox[{"SparseArray", "[", 
              RowBox[{
               RowBox[{"{", "}"}], ",", 
               RowBox[{"{", 
                RowBox[{"dim", ",", "dim"}], "}"}]}], "]"}], ",", 
             RowBox[{"SparseArray", "[", 
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "1", "]"}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"dim", ",", "dim"}], "}"}]}], "]"}]}], "]"}], "&"}], 
          ",", "rules"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{
        "\"\<Generated S4 Matrices for N=\>\"", ",", "Nint", ",", 
         "\"\< (Dimension d=\>\"", ",", "dim", ",", "\"\<)\>\""}], "]"}], ";",
        "\[IndentingNewLine]", "mats"}]}], "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.991136355513191*^9, 3.9911363560720043`*^9}},
