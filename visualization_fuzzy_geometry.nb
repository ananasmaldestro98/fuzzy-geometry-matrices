Cell[CellGroupData[{

Cell["Section 2. Unified Analysis Function", "Section",
 CellChangeTimes->{3.991136372556452*^9, 
  3.9912110800917587`*^9},ExpressionUUID->"e272b15c-3dca-3141-bf47-\
0d9f025e9595"],

Cell["\<\
Here we define the function that allows to compute the quasi-coherent state \
that localize the fuzzy geometry, and allows to visualize the effective \
manifold, for a given set of matrices, potentially adding noise.\
\>", "Text",
 CellChangeTimes->{{3.991211357472927*^9, 
  3.9912114124871006`*^9}},ExpressionUUID->"a19fbdd1-01d9-fd4e-b84d-\
ddcbbe616a2e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "AnalyzeFuzzyGeometry", "]"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<NumPoints\>\"", "->", "5000"}], ",", 
      RowBox[{"\"\<PointRange\>\"", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "2"}], ",", "2"}], "}"}]}], ",", 
      RowBox[{"\"\<NoiseLevel\>\"", "->", "0.0"}], ",", 
      RowBox[{"\"\<PlotIndices\>\"", "->", 
       RowBox[{"{", 
        RowBox[{"1", ",", "2", ",", "3"}], "}"}]}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"AnalyzeFuzzyGeometry", "[", 
   RowBox[{"matrices_List", ",", 
    RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "n", ",", "k", ",", "numPts", ",", "pRange", ",", "noiseLvl", ",", 
      "pIdx", ",", "noisyMatrices", ",", "randomPoints", ",", "id", ",", 
      "computeExp", ",", "expectationValues"}], "}"}], ",", 
    RowBox[{
     RowBox[{"n", "=", 
      RowBox[{"Length", "[", 
       RowBox[{"matrices", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"k", "=", 
      RowBox[{"Length", "[", "matrices", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"numPts", "=", 
      RowBox[{"OptionValue", "[", "\"\<NumPoints\>\"", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"pRange", "=", 
      RowBox[{"OptionValue", "[", "\"\<PointRange\>\"", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"noiseLvl", "=", 
      RowBox[{"OptionValue", "[", "\"\<NoiseLevel\>\"", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"pIdx", "=", 
      RowBox[{"OptionValue", "[", "\"\<PlotIndices\>\"", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "Inject", " ", "Gaussian", " ", "noise", " ", "into", " ", "the", " ", 
        "matrices", " ", "to", " ", "test", " ", "stability"}], ",", 
       RowBox[{"if", " ", "requested"}]}], "*)"}], 
     RowBox[{"noisyMatrices", "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"noiseLvl", ">", "0"}], ",", 
        RowBox[{"matrices", "+", 
         RowBox[{"noiseLvl", "*", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"Module", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"A", "=", 
                RowBox[{"RandomVariate", "[", 
                 RowBox[{
                  RowBox[{"NormalDistribution", "[", 
                   RowBox[{"0", ",", "1"}], "]"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"n", ",", "n"}], "}"}]}], "]"}]}], "}"}], ",", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"A", "+", 
                 RowBox[{"ConjugateTranspose", "[", "A", "]"}]}], ")"}], "/", 
               "2"}]}], "]"}], ",", 
            RowBox[{"{", "k", "}"}]}], "]"}]}]}], ",", "matrices"}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"randomPoints", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{"pRange", ",", 
        RowBox[{"{", 
         RowBox[{"numPts", ",", "k"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"id", "=", 
      RowBox[{"IdentityMatrix", "[", 
       RowBox[{"n", ",", 
        RowBox[{"WorkingPrecision", "->", "MachinePrecision"}]}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "Computes", " ", "the", " ", "expectation", " ", "values", " ", "of", 
       " ", "the", " ", "matrices", " ", "in", " ", "the", " ", "ground", " ",
        "state"}], "*)"}], 
     RowBox[{
      RowBox[{"computeExp", "[", "point_", "]"}], ":=", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"H", ",", "groundState"}], "}"}], ",", 
        RowBox[{
         RowBox[{"H", "=", 
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"noisyMatrices", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "-", 
               RowBox[{
                RowBox[{"point", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "*", "id"}]}], ")"}], ".", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"noisyMatrices", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "-", 
               RowBox[{
                RowBox[{"point", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "*", "id"}]}], ")"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "1", ",", "k"}], "}"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"groundState", "=", 
          RowBox[{"Normalize", "[", 
           RowBox[{"First", "[", 
            RowBox[{"Eigenvectors", "[", 
             RowBox[{
              RowBox[{"N", "[", "H", "]"}], ",", 
              RowBox[{"-", "1"}]}], "]"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Re", "[", 
          RowBox[{"Map", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"Conjugate", "[", "groundState", "]"}], ".", "#", ".", 
              "groundState"}], "&"}], ",", "noisyMatrices"}], "]"}], 
          "]"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{
      "\"\<Computing coherent states for \>\"", ",", "numPts", ",", 
       "\"\< points in \>\"", ",", "k", ",", 
       "\"\< dimensions (Matrix Size: \>\"", ",", "n", ",", "\"\<x\>\"", ",", 
       "n", ",", "\"\<)...\>\""}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "Distribute", " ", "load", " ", "across", " ", "CPU", " ", "cores"}], 
      "*)"}], 
     RowBox[{"expectationValues", "=", 
      RowBox[{"ParallelMap", "[", 
       RowBox[{"computeExp", ",", "randomPoints"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"ListPointPlot3D", "[", 
        RowBox[{
         RowBox[{"randomPoints", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "pIdx"}], "]"}], "]"}], ",", 
         RowBox[{"PlotStyle", "->", "Red"}], ",", 
         RowBox[{"AxesLabel", "->", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"StringJoin", "[", 
              RowBox[{"\"\<x\>\"", ",", 
               RowBox[{"ToString", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
            "pIdx"}], ")"}]}], ",", 
         RowBox[{"PlotRange", "->", "All"}], ",", 
         RowBox[{"Boxed", "->", "True"}], ",", 
         RowBox[{"PlotLabel", "->", "\"\<Target Space\>\""}]}], "]"}], ",", 
       RowBox[{"ListPointPlot3D", "[", 
        RowBox[{
         RowBox[{"expectationValues", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "pIdx"}], "]"}], "]"}], ",", 
         RowBox[{"PlotStyle", "->", "Blue"}], ",", 
         RowBox[{"AxesLabel", "->", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"StringJoin", "[", 
              RowBox[{"\"\<<X\>\"", ",", 
               RowBox[{"ToString", "[", "#", "]"}], ",", "\"\<>\>\""}], "]"}],
              "&"}], "/@", "pIdx"}], ")"}]}], ",", 
         RowBox[{"PlotRange", "->", "All"}], ",", 
         RowBox[{"Boxed", "->", "True"}], ",", 
         RowBox[{"PlotLabel", "->", "\"\<Fuzzy Space Coherent States\>\""}]}],
         "]"}]}], "}"}]}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.99113638285158*^9, 3.9911363828540936`*^9}},
 CellLabel->
  "In[157]:=",ExpressionUUID->"f8c81504-e120-044e-8432-eea95667fb39"]
}, Open  ]],

